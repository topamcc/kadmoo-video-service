# Every comment line must start with # at the beginning of the line (no space before #).

# API auth (must match VIDEO_SERVICE_API_KEY in Next.js)
API_KEY=vs_change_me

# Redis (Celery broker + job state)
# Docker Compose: redis://redis:6379/0
# RunPod without Docker: redis://127.0.0.1:6379/0
REDIS_URL=redis://redis:6379/0

# Webhook HMAC (must match VIDEO_SERVICE_WEBHOOK_SECRET in Next.js)
WEBHOOK_HMAC_SECRET=whsec_change_me

# Supabase - upload final MP4 to studio-assets
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=studio-assets

# ElevenLabs v3 - Hebrew TTS + IVC
ELEVENLABS_API_KEY=
# When no voice_sample_url on job, use this premade voice id:
ELEVENLABS_DEFAULT_VOICE_ID=

# LTX-2 — see docs/LTX2-INSTALL-RUNPOD.md and docs/LTX2-ASSET-CHECKLIST.md
LTX_STUB_MODE=true
LTX_MODEL_PATH=
LTX_UPSCALER_PATH=
LTX_PYTHON_BIN=
LTX_HF_MODEL_ID=Lightricks/LTX-2.3
LTX_USE_SPATIAL_UPSCALER=false
LTX_REPO_PATH=
# Gemma encoder tree (required for official ltx_pipelines, not Diffusers-only)
LTX_GEMMA_ROOT=
# Set true on GPU host with full assets to use python -m ltx_pipelines.* (two_stage_hq / distilled_fast)
LTX_USE_OFFICIAL_PIPELINES=false
LTX_DISTILLED_LORA_PATH=
LTX_DISTILLED_LORA_STRENGTH=0.8
# Legacy: custom module name; official path uses fixed ltx_pipelines.* mapping when LTX_USE_OFFICIAL_PIPELINES=true
LTX_OFFICIAL_I2V_MODULE=
# Multi-keyframe: concat (per-scene + ffmpeg) | keyframe_interpolation (single official KIP run)
LTX_MULTI_KEYFRAME_STRATEGY=concat
# audio_to_video jobs: i2v_mux | a2vid_two_stage
LTX_AUDIO_TO_VIDEO_PIPELINE=i2v_mux
LTX_TRAINER_CONFIG_TEMPLATE=
FP8_QUANTIZATION=false

# Optional BGM (Replicate MusicGen)
REPLICATE_API_TOKEN=

# Runtime
TEMP_DIR=/tmp/kadmoo-video
JOB_TIMEOUT_SECONDS=600
HOST=0.0.0.0
PORT=4100
